      "group": "present-tense-tag",
      "instruction": "Learn the Somali present-tense markers for `tag-`, then answer mixed prompts one at a time.",
      "tableTitle": "Present tense of `tag-`",
      "columnHeaders": {
        "label": "Person",
        "prompt": "English cue",
        "answer": "Somali form"
      },
      "rows": [
        {
          "id": "pt-lesson-s-1",
          "label": "I",
          "prompt": "I am going.",
          "answers": [
            "Waan tagayaa."
          ]
        },
        {
          "id": "pt-lesson-s-2",
          "label": "You",
          "prompt": "You are going.",
          "answers": [
            "Waad tagaysaa."
          ]
        },
        {
          "id": "pt-lesson-s-3",
          "label": "He",
          "prompt": "He is going.",
          "answers": [
            "Wuu tagayaa."
          ]
        },
        {
          "id": "pt-lesson-s-4",
          "label": "She",
          "prompt": "She is going.",
          "answers": [
            "Way tagaysaa."
          ]
        },
        {
