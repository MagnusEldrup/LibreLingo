      "lessonSlides": [
        {
          "id": "pt-slide-1",
          "title": "Start with the singular markers",
          "description": "In the affirmative present tense, Somali places a short subject marker before the verb. Read these four examples aloud and notice how the marker changes with the person.",
          "focusPoints": [
            "`waan` = I",
            "`waad` = you",
            "`wuu` = he",
            "`way` = she or they"
          ],
          "rows": [
            {
              "id": "pt-lesson-s-1",
              "label": "I",
              "prompt": "I am going.",
              "answers": [
                "Waan tagayaa."
              ]
            },
            {
              "id": "pt-lesson-s-2",
              "label": "You",
              "prompt": "You are going.",
              "answers": [
                "Waad tagaysaa."
              ]
            },
            {
              "id": "pt-lesson-s-3",
              "label": "He",
              "prompt": "He is going.",
              "answers": [
                "Wuu tagayaa."
              ]
            },
            {
              "id": "pt-lesson-s-4",
              "label": "She",
              "prompt": "She is going.",
              "answers": [
                "Way tagaysaa."
              ]
            }
          ]
        },
        {
          "id": "pt-slide-2",
          "title": "Plural forms add one important split",
          "description": "The plural pattern keeps the same idea, but Somali distinguishes between inclusive and exclusive `we`. Learn that contrast before you practice.",
          "focusPoints": [
            "`waynu` includes the person you are speaking to",
            "`waannu` excludes the person you are speaking to",
            "`waydin` marks `you all`"
          ],
          "rows": [
            {
              "id": "pt-lesson-p-1",
              "label": "We (including you)",
              "prompt": "We are going, including you.",
              "answers": [
                "Waynu tagaynaa.",
                "Waynu tagayna."
              ]
            },
            {
              "id": "pt-lesson-p-2",
              "label": "We (not including you)",
              "prompt": "We are going, not including you.",
              "answers": [
                "Waannu tagaynaa.",
                "Waannu tagayna."
              ]
            },
            {
              "id": "pt-lesson-p-3",
              "label": "You all",
              "prompt": "You all are going.",
              "answers": [
                "Waydin tagaysaan."
              ]
            },
            {
              "id": "pt-lesson-p-4",
              "label": "They",
              "prompt": "They are going.",
              "answers": [
                "Way tagayaan."
              ]
            }
          ]
        },
        {
          "id": "pt-slide-3",
          "title": "Look for the pattern, not the sentence",
          "description": "The goal is to recognize the subject marker and then build the full present-tense sentence. The next screen asks new questions so learners have to apply the pattern instead of copying a table.",
          "focusPoints": [
            "Marker first, then the present-tense verb form",
            "The same idea works even when the cue changes",
            "Practice rows use fresh wording"
          ]
        }
      ],
      "practiceRows": [
