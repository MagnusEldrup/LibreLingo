        },
        {
          "id": "pt-lesson-p-4",
          "label": "They",
          "prompt": "They are going.",
          "answers": [
            "Way tagayaan."
          ]
        }
      ],
      "lessonSlides": [
        {
          "id": "pt-slide-1",
          "title": "Start with the singular markers",
          "description": "In the affirmative present tense, Somali puts a short subject marker before the verb. Read these examples aloud and notice which marker goes with each person.",
          "focusPoints": [
            "Use `waan` with `I`",
            "Use `waad` with `you`",
            "Use `wuu` with `he`",
            "Use `way` with `she` and often with `they`"
          ],
          "rows": [
            {
              "id": "pt-lesson-s-1",
              "label": "I",
              "prompt": "I am going.",
              "answers": [
                "Waan tagayaa."
              ]
            },
            {
              "id": "pt-lesson-s-2",
              "label": "You",
              "prompt": "You are going.",
              "answers": [
                "Waad tagaysaa."
              ]
            },
            {
              "id": "pt-lesson-s-3",
              "label": "He",
              "prompt": "He is going.",
              "answers": [
                "Wuu tagayaa."
              ]
            },
            {
              "id": "pt-lesson-s-4",
              "label": "She",
              "prompt": "She is going.",
              "answers": [
                "Way tagaysaa."
              ]
            }
          ]
        },
        {
          "id": "pt-slide-2",
          "title": "Plural forms add one important split",
          "description": "The plural forms follow the same idea, but Somali distinguishes between inclusive and exclusive `we`. Learn that contrast before you practise.",
          "focusPoints": [
            "`waynu` includes the person you are speaking to",
            "`waannu` excludes the person you are speaking to",
            "Use `waydin` for `you all`"
          ],
          "rows": [
            {
              "id": "pt-lesson-p-1",
              "label": "We (including you)",
              "prompt": "We are going, including you.",
              "answers": [
                "Waynu tagaynaa.",
                "Waynu tagayna."
              ]
            },
            {
              "id": "pt-lesson-p-2",
              "label": "We (not including you)",
              "prompt": "We are going, not including you.",
              "answers": [
                "Waannu tagaynaa.",
                "Waannu tagayna."
              ]
            },
            {
              "id": "pt-lesson-p-3",
              "label": "You all",
              "prompt": "You all are going.",
              "answers": [
                "Waydin tagaysaan."
              ]
            },
            {
              "id": "pt-lesson-p-4",
              "label": "They",
              "prompt": "They are going.",
              "answers": [
                "Way tagayaan."
              ]
            }
          ]
        },
        {
          "id": "pt-slide-3",
          "title": "Look for the pattern, not the sentence",
          "description": "Now focus on the pattern rather than memorizing a whole table. In practice, you will answer mixed prompts one by one.",
          "focusPoints": [
            "Start with the subject marker",
            "Then add the present-tense verb form",
            "Keep the same pattern even when the cue words change"
          ]
        }
      ],
      "practiceRows": [
        {
          "id": "pt-practice-1",
          "label": "I",
          "prompt": "I am going today.",
          "rule": "Use `waan` for `I`, then add the present-tense verb.",
          "answers": [
            "Waan tagayaa maanta."
          ]
        },
        {
          "id": "pt-practice-2",
          "label": "You",
          "prompt": "You are going now.",
          "rule": "Use `waad` for `you`, then add the present-tense verb.",
          "answers": [
            "Waad tagaysaa hadda."
          ]
        },
        {
          "id": "pt-practice-3",
          "label": "He",
          "prompt": "He is going to the market.",
          "rule": "Use `wuu` for `he`, then add the present-tense verb.",
          "answers": [
            "Wuu tagayaa suuqa."
          ]
        },
        {
          "id": "pt-practice-4",
          "label": "She",
          "prompt": "She is going home.",
          "rule": "Use `way` for `she`, then add the present-tense verb.",
          "answers": [
            "Way tagaysaa guriga."
          ]
        },
        {
          "id": "pt-practice-5",
          "label": "We (including you)",
          "prompt": "We are going together, including you.",
          "rule": "Use `waynu` when `we` includes the person you are speaking to.",
          "answers": [
            "Waynu wada tagaynaa.",
            "Waynu wada tagayna."
          ]
        },
        {
          "id": "pt-practice-6",
          "label": "We (not including you)",
          "prompt": "We are going together, not including you.",
          "rule": "Use `waannu` when `we` does not include the person you are speaking to.",
          "answers": [
            "Waannu wada tagaynaa.",
            "Waannu wada tagayna."
          ]
        },
        {
          "id": "pt-practice-7",
          "label": "You all",
          "prompt": "You all are going to school.",
          "rule": "Use `waydin` for `you all`, then add the present-tense verb.",
          "answers": [
            "Waydin tagaysaan dugsiga."
          ]
        },
        {
          "id": "pt-practice-8",
          "label": "They",
          "prompt": "They are going tomorrow.",
          "rule": "Use `way` for `they` here, then add the plural present-tense verb.",
          "answers": [
            "Way tagayaan berri."
          ]
        }
      ]
    }
  ]
