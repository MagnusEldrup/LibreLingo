      "group": "linking-patterns",
      "instruction": "Apply the Somali linking chunks used in common sentence frames. The lesson screens explain what each chunk does before the practice rows switch to new cues.",
      "tableTitle": "Linking patterns: `oo`, `inuu`, `ka`, `si uu u`",
      "columnHeaders": {
        "label": "Pattern",
        "prompt": "English cue",
        "answer": "Somali pattern"
      },
      "rows": [
        {
          "id": "lp-lesson-1",
          "label": "oo",
          "prompt": "Maxamed and his wife, who is called Khadra",
          "answers": [
